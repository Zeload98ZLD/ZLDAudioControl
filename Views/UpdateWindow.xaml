<Window x:Class="HerculesAudioControl.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Updates"
        Width="620" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Update Center" FontSize="32" FontWeight="Bold"/>
            <TextBlock x:Name="CurrentVersionText"
                       Foreground="{DynamicResource MutedTextBrush}"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{DynamicResource PanelBrush}"
                CornerRadius="18" Padding="22" Margin="0,24,0,16">
            <StackPanel>
                <TextBlock Text="GitHub Releases" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="Repository-Inhaber" Margin="0,16,0,6"/>
                <TextBox x:Name="OwnerBox" Height="38" Padding="10,7"
                         Background="{DynamicResource BackgroundBrush}"
                         Foreground="{DynamicResource TextBrush}"/>
                <TextBlock Text="Repository-Name" Margin="0,14,0,6"/>
                <TextBox x:Name="RepositoryBox" Height="38" Padding="10,7"
                         Background="{DynamicResource BackgroundBrush}"
                         Foreground="{DynamicResource TextBrush}"/>
                <CheckBox x:Name="StartupCheck"
                          Content="Beim Programmstart nach Updates suchen"
                          Margin="0,16,0,0"/>
            </StackPanel>
        </Border>

        <Button Grid.Row="2" Content="Jetzt nach Updates suchen"
                HorizontalAlignment="Left"
                Click="Check_Click"/>

        <Border Grid.Row="3" Background="{DynamicResource PanelBrush}"
                CornerRadius="18" Padding="20" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="Status" FontWeight="Bold"/>
                <TextBlock x:Name="StatusText" Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
                <Button x:Name="OpenReleaseButton"
                        Content="Release-Seite öffnen"
                        Visibility="Collapsed"
                        HorizontalAlignment="Left"
                        Margin="0,16,0,0"
                        Click="OpenRelease_Click"/>
            </StackPanel>
        </Border>

        <Button Grid.Row="4" Content="Speichern und schließen"
                HorizontalAlignment="Right"
                Margin="0,18,0,0"
                Click="SaveClose_Click"/>
    </Grid>
</Window>
