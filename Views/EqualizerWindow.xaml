<Window x:Class="HerculesAudioControl.Views.EqualizerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Equalizer"
        Width="720" Height="690"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid>
                <StackPanel>
                    <TextBlock Text="Equalizer" FontSize="32" FontWeight="Bold"/>
                    <TextBlock Text="Live-Steuerung über Equalizer APO"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,5,0,0"/>
                </StackPanel>
                <CheckBox x:Name="EnabledCheck"
                          Content="EQ aktiv"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          FontSize="15"
                          Checked="EnabledChanged"
                          Unchecked="EnabledChanged"/>
            </Grid>

            <Border Grid.Row="1" Background="{DynamicResource PanelBrush}"
                    CornerRadius="18" Padding="22" Margin="0,24,0,16">
                <StackPanel>
                    <TextBlock Text="Klangregelung" FontSize="21" FontWeight="Bold"/>

                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="125"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Bass" VerticalAlignment="Center"/>
                        <Slider x:Name="BassSlider" Grid.Column="1" Minimum="-12" Maximum="12"
                                ValueChanged="GainChanged"/>
                        <TextBlock x:Name="BassValue" Grid.Column="2"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button Grid.Column="3" Content="MIDI lernen" Tag="EqBass"
                                Click="LearnMidi_Click"/>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="125"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Mitten" VerticalAlignment="Center"/>
                        <Slider x:Name="MidSlider" Grid.Column="1" Minimum="-12" Maximum="12"
                                ValueChanged="GainChanged"/>
                        <TextBlock x:Name="MidValue" Grid.Column="2"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button Grid.Column="3" Content="MIDI lernen" Tag="EqMid"
                                Click="LearnMidi_Click"/>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="125"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Höhen" VerticalAlignment="Center"/>
                        <Slider x:Name="TrebleSlider" Grid.Column="1" Minimum="-12" Maximum="12"
                                ValueChanged="GainChanged"/>
                        <TextBlock x:Name="TrebleValue" Grid.Column="2"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button Grid.Column="3" Content="MIDI lernen" Tag="EqTreble"
                                Click="LearnMidi_Click"/>
                    </Grid>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="125"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Filter" VerticalAlignment="Center"/>
                        <Slider x:Name="FilterSlider" Grid.Column="1" Minimum="0" Maximum="100"
                                ValueChanged="GainChanged"/>
                        <TextBlock x:Name="FilterValue" Grid.Column="2"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Button Grid.Column="3" Content="MIDI lernen" Tag="EqFilter"
                                Click="LearnMidi_Click"/>
                    </Grid>

                    <TextBlock x:Name="BindingsText" Margin="0,20,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="{DynamicResource PanelBrush}"
                    CornerRadius="18" Padding="22" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Equalizer-APO-Verbindung"
                               FontSize="21" FontWeight="Bold"/>
                    <TextBlock x:Name="ApoStatusText" Margin="0,10,0,10"
                               TextWrapping="Wrap"/>
                    <TextBox x:Name="OutputFileBox" Height="38" Padding="10,7"
                             Background="{DynamicResource BackgroundBrush}"
                             Foreground="{DynamicResource TextBrush}"
                             TextChanged="OutputFileChanged"/>
                    <TextBlock Margin="0,10,0,0"
                               Foreground="{DynamicResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Text="In C:\Program Files\EqualizerAPO\config\config.txt muss stehen: Include: hercules_dynamic.txt"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Zurücksetzen" Background="{DynamicResource SecondaryBrush}"
                        Margin="0,0,10,0" Click="Reset_Click"/>
                <Button Content="Jetzt anwenden" Click="Apply_Click"/>
            </StackPanel>

            <TextBlock Grid.Row="4" x:Name="StatusText"
                       Margin="0,16,0,0"
                       Foreground="{DynamicResource Accent2Brush}"
                       TextWrapping="Wrap"/>
        </Grid>
    </ScrollViewer>
</Window>
