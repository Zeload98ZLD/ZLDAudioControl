<Window x:Class="HerculesAudioControl.Views.ProcessPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Audioquelle hinzufügen"
        Width="780"
        Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <StackPanel>
                <TextBlock Text="Audioquelle hinzufügen"
                           FontSize="31"
                           FontWeight="Bold"/>
                <TextBlock Text="Hier erscheinen alle Quellen, die Windows aktuell im Lautstärkemixer erkennt."
                           Foreground="{DynamicResource MutedTextBrush}"
                           Margin="0,6,0,0"/>
            </StackPanel>

            <Button Content="⟳ Aktualisieren"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SecondaryBrush}"
                    BorderBrush="{DynamicResource Accent2Brush}"
                    Click="Refresh_Click"/>
        </Grid>

        <TextBox x:Name="SearchBox"
                 Grid.Row="1"
                 Margin="0,22,0,16"
                 Height="44"
                 Padding="13,8"
                 TextChanged="SearchBox_TextChanged"/>

        <Border Grid.Row="2"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14"
                Margin="0,0,0,14">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Tipp"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Accent2Brush}"/>
                    <TextBlock Text="Fehlt ein Spiel oder Programm? Starte dort kurz eine Audioausgabe und klicke anschließend auf Aktualisieren."
                               Margin="0,5,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>

                <TextBlock x:Name="SourceCountText"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Accent3Brush}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <ListBox x:Name="ProcessList"
                     Background="{DynamicResource PanelBrush}"
                     Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource BorderBrush}"
                     BorderThickness="1"
                     MouseDoubleClick="ProcessList_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="13"
                                Margin="4"
                                CornerRadius="12"
                                Background="{DynamicResource Panel2Brush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="145"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="42"
                                        Height="42"
                                        CornerRadius="11"
                                        Background="{DynamicResource PanelHoverBrush}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding Initial}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource Accent2Brush}"/>
                                </Border>

                                <StackPanel Grid.Column="1"
                                            Margin="12,0,12,0">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,4,0,0">
                                        <TextBlock Text="{Binding ProcessName}"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                        <TextBlock Text="{Binding SessionCount, StringFormat={} · {0} Sitzung(en)}"
                                                   Foreground="{DynamicResource MutedTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center">
                                    <Grid>
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="{DynamicResource Accent2Brush}"/>
                                        <TextBlock Text="{Binding VolumePercent, StringFormat={}{0} %}"
                                                   HorizontalAlignment="Right"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                    </Grid>
                                    <ProgressBar Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding PeakPercent}"
                                                 Height="7"
                                                 Margin="0,7,0,0"
                                                 Foreground="{DynamicResource Accent2Brush}"
                                                 Background="{DynamicResource SecondaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border x:Name="EmptyState"
                    Visibility="Collapsed"
                    Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="34">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Keine Audioquellen gefunden"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock Text="Starte eine Tonwiedergabe und aktualisiere anschließend die Liste."
                               Margin="0,8,0,16"
                               TextAlignment="Center"
                               Foreground="{DynamicResource MutedTextBrush}"/>
                    <Button Content="⟳ Erneut suchen"
                            Click="Refresh_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Abbrechen"
                    Background="{DynamicResource SecondaryBrush}"
                    Margin="0,0,10,0"
                    Click="Cancel_Click"/>
            <Button Content="Audioquelle hinzufügen"
                    Click="Add_Click"/>
        </StackPanel>
    </Grid>
</Window>
